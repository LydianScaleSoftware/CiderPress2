<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cp2_avalonia.LibTest"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d"
        x:Class="cp2_avalonia.LibTest.TestManager"
        Title="Library Test Runner"
        Width="1024" Height="768" MinWidth="640" MinHeight="480"
        CanResize="True"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Name="runButton" Content="{Binding RunButtonLabel, FallbackValue=Run Test}"
                    Width="120" FontWeight="Bold" IsEnabled="{Binding IsNotRunning}"
                    Click="RunCancelButton_Click"/>
            <CheckBox Content="Retain output" Margin="20,3,0,0"
                      IsChecked="{Binding IsOutputRetained}"/>
        </StackPanel>

        <Button DockPanel.Dock="Bottom" Content="Close" Width="70" IsCancel="True"
                HorizontalAlignment="Right" Margin="0,8,0,0"
                Click="CloseButton_Click"/>

        <!-- Colored progress output using AvaloniaEdit TextEditor (read-only) -->
        <!-- Thread-safety note (G-01): All AvaloniaEdit document mutations must happen on the
             UI thread. BackgroundWorker.ProgressChanged fires on the UI thread, so appends
             there are safe. Do NOT append inside DoWork. -->
        <avaloniaEdit:TextEditor Name="progressTextEditor"
                                  DockPanel.Dock="Top"
                                  Height="200" Margin="0,8,0,0"
                                  IsReadOnly="True"
                                  FontFamily="{StaticResource GeneralMonoFont}"
                                  FontSize="12"
                                  ShowLineNumbers="False"
                                  WordWrap="False"/>

        <ComboBox DockPanel.Dock="Top" Name="outputSelectComboBox"
                  Margin="0,20,0,0" Width="360"
                  HorizontalAlignment="Left"
                  IsEnabled="{Binding IsOutputSelectEnabled}"
                  ItemsSource="{Binding OutputItems}"
                  SelectionChanged="OutputSelectComboBox_SelectedIndexChanged"/>

        <TextBox DockPanel.Dock="Top" Name="outputTextBox"
                 IsReadOnly="True" Margin="0,8,0,0"
                 TextWrapping="NoWrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
