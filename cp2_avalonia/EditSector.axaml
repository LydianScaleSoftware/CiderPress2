<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cp2_avalonia"
        xmlns:common="clr-namespace:cp2_avalonia.Common"
        mc:Ignorable="d"
        x:Class="cp2_avalonia.EditSector"
        Title="Edit THING"
        SizeToContent="Width" Height="560" CanResize="True"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Opened="Window_Opened"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Column 0: label and sector edit DataGrid -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="{Binding SectorDataLabel, FallbackValue=LABEL}"
                   HorizontalAlignment="Center"/>

        <DataGrid Name="sectorDataGrid" Grid.Row="1" Grid.Column="0" Margin="0,4,8,0"
                  ItemsSource="{Binding SectorData}"
                  IsVisible="{Binding IsSectorDataGridVisible}"
                  IsReadOnly="True"
                  GridLinesVisibility="None"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="False"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  CurrentCellChanged="SectorDataGrid_CurrentCellChanged"
                  KeyDown="SectorDataGrid_KeyDown"
                  FontFamily="{StaticResource GeneralMonoFont}">
            <DataGrid.Styles>
                <!-- Suppress row-level selection highlight; cell CurrencyVisual
                     provides single-cell focus indicator -->
                <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
                <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
                <Style Selector="DataGridRow:selected:focus /template/ Rectangle#BackgroundRectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
                <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
                    <Setter Property="Fill" Value="Transparent"/>
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <!-- Column 0: offset (frozen, acts as row header) -->
                <DataGridTextColumn Header="" Binding="{Binding RowLabel}"
                    IsReadOnly="True" Width="Auto"
                    CellStyleClasses="RowHeaderCell"/>
                <!-- Columns 1-16: hex bytes -->
                <DataGridTextColumn Header="0" Binding="{Binding C0}" Width="Auto"/>
                <DataGridTextColumn Header="1" Binding="{Binding C1}" Width="Auto"/>
                <DataGridTextColumn Header="2" Binding="{Binding C2}" Width="Auto"/>
                <DataGridTextColumn Header="3" Binding="{Binding C3}" Width="Auto"/>
                <DataGridTextColumn Header="4" Binding="{Binding C4}" Width="Auto"/>
                <DataGridTextColumn Header="5" Binding="{Binding C5}" Width="Auto"/>
                <DataGridTextColumn Header="6" Binding="{Binding C6}" Width="Auto"/>
                <DataGridTextColumn Header="7" Binding="{Binding C7}" Width="Auto"/>
                <DataGridTextColumn Header="8" Binding="{Binding C8}" Width="Auto"/>
                <DataGridTextColumn Header="9" Binding="{Binding C9}" Width="Auto"/>
                <DataGridTextColumn Header="A" Binding="{Binding Ca}" Width="Auto"/>
                <DataGridTextColumn Header="B" Binding="{Binding Cb}" Width="Auto"/>
                <DataGridTextColumn Header="C" Binding="{Binding Cc}" Width="Auto"/>
                <DataGridTextColumn Header="D" Binding="{Binding Cd}" Width="Auto"/>
                <DataGridTextColumn Header="E" Binding="{Binding Ce}" Width="Auto"/>
                <DataGridTextColumn Header="F" Binding="{Binding Cf}" Width="Auto"/>
                <!-- Column 17: ASCII text -->
                <DataGridTextColumn Header="Text" Binding="{Binding AsText}"
                    IsReadOnly="True" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="{Binding IOErrorMsg}"
                   FontSize="20"
                   IsVisible="{Binding IsIOErrorMsgVisible}"/>

        <!-- Column 1: control panel on right side -->
        <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="1" Grid.RowSpan="4" Margin="4,0,4,0"
                   HorizontalAlignment="Center" Width="1"
                   Stroke="{DynamicResource SystemControlForegroundBaseLowBrush}" Fill="Transparent"/>

            <!-- Column 1, left side: location edit boxes and navigation buttons -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,4"
                            Background="{DynamicResource SubSectionHeaderBrush}">
                        <TextBlock Text="Location" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2,0,0"
                           Text="{Binding TrackBlockLabel, FallbackValue=Track:}"
                           Foreground="{Binding TrackBlockLabelForeground}"/>
                    <TextBox Name="trackBlockNumBox" Grid.Row="1" Grid.Column="1" Margin="8,2,0,0"
                         Text="{Binding TrackBlockNumString, UpdateSourceTrigger=PropertyChanged}"
                         Width="75" MaxLength="12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,0,0"
                           Text="Sector:"
                           IsVisible="{Binding IsSectorVisible}"
                           Foreground="{Binding SectorLabelForeground}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="8,4,0,0"
                         IsVisible="{Binding IsSectorVisible}"
                         Text="{Binding SectorNumString, UpdateSourceTrigger=PropertyChanged}"
                         Width="75" MaxLength="4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0"
                           Text="{Binding TrackBlockInfoLabel, FallbackValue=o INFO1}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                           IsVisible="{Binding IsSectorVisible}"
                           Text="{Binding SectorInfoLabel, FallbackValue=o INFO2}"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Width="40" Margin="0,0,5,0"
                        Content="_Prev" HorizontalAlignment="Right"
                        IsEnabled="{Binding IsPrevEnabled}"
                        Click="PrevButton_Click"/>
                    <Button Grid.Column="1" Width="40" Margin="5,0,0,0"
                        Content="_Next" HorizontalAlignment="Left"
                        IsEnabled="{Binding IsNextEnabled}"
                        Click="NextButton_Click"/>
                </Grid>

                <Button Grid.Row="2" Width="90" Content="_Read" Margin="0,16,0,0"
                    IsDefault="True"
                    IsEnabled="{Binding IsReadButtonEnabled}"
                    Click="ReadButton_Click"/>
                <Button Grid.Row="3" Width="90" Content="_Write" Margin="0,16,0,0"
                    IsEnabled="{Binding IsWriteButtonEnabled}"
                    Click="WriteButton_Click"/>
                <Button Grid.Row="4" Width="110" Content="Copy to Clipboard" Margin="0,16,0,0"
                    Click="CopyButton_Click"/>
            </Grid>

            <!-- Column 1, right side: advanced configuration -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,4"
                        Background="{DynamicResource SubSectionHeaderBrush}">
                    <TextBlock Text="Configuration" HorizontalAlignment="Center"/>
                </StackPanel>

                <common:GroupBox Grid.Row="1" Header="Text Conversion" Padding="2,4">
                    <StackPanel>
                        <RadioButton GroupName="TxtConv" Content="High/low ASCII"
                                     IsChecked="{Binding IsChecked_ConvHighASCII}"/>
                        <RadioButton GroupName="TxtConv" Content="Mac OS Roman" Margin="0,2,0,0"
                                     IsChecked="{Binding IsChecked_ConvMOR}"/>
                        <RadioButton GroupName="TxtConv" Content="ISO Latin-1" Margin="0,2,0,0"
                                     IsChecked="{Binding IsChecked_ConvLatin}"/>
                    </StackPanel>
                </common:GroupBox>

                <common:GroupBox Grid.Row="2" Header="Advanced" Padding="2,4">
                    <StackPanel>
                        <TextBlock Text="Block order:"
                                   IsVisible="{Binding IsBlockOrderVisible}"/>
                        <ComboBox Name="blockOrderCombo" HorizontalAlignment="Stretch" Margin="0,2,0,0"
                                  IsVisible="{Binding IsBlockOrderVisible}"
                                  IsEnabled="{Binding IsBlockOrderEnabled}"
                                  SelectionChanged="BlockOrderCombo_SelectionChanged"/>

                        <TextBlock Text="Sector skew:" Margin="0,8,0,0"/>
                        <ComboBox Name="sectorOrderCombo" HorizontalAlignment="Stretch" Margin="0,2,0,0"
                                  IsEnabled="{Binding IsSectorOrderEnabled}"
                                  SelectionChanged="SectorOrderCombo_SelectionChanged"/>

                        <TextBlock Text="Sector format:" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding SectorCodecName, FallbackValue=DOS_33}" Margin="4,4,0,0"/>
                    </StackPanel>
                </common:GroupBox>
            </Grid>
        </Grid>

        <Button Grid.Row="3" Grid.ColumnSpan="3" Name="closeButton" Content="Close" IsCancel="True"
                Width="90" Margin="0,12,0,0" HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
